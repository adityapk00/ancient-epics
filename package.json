{
  "name": "ancient-epics",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm --filter @ancient-epics/api dev\" \"pnpm --filter @ancient-epics/web dev\"",
    "e2e:dev": "pnpm --filter @ancient-epics/api local:db:nuke && pnpm --filter @ancient-epics/api local:db:seed && pnpm --filter @ancient-epics/api local:admin:password password && pnpm dev",
    "build": "pnpm -r build",
    "cf:setup": "node ./scripts/cloudflare-setup.mjs",
    "cf:deploy": "node ./scripts/cloudflare-deploy.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @ancient-epics/api test",
    "test:ui": "node ./scripts/test-ui.mjs",
    "test:ui:server": "node ./scripts/ui-test-server.mjs",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "local:db:migrate": "pnpm --filter @ancient-epics/api local:db:migrate",
    "remote:db:migrate": "pnpm --filter @ancient-epics/api remote:db:migrate",
    "local:db:seed": "pnpm --filter @ancient-epics/api local:db:seed",
    "remote:db:seed": "pnpm --filter @ancient-epics/api remote:db:seed",
    "local:admin:password": "pnpm --filter @ancient-epics/api local:admin:password",
    "remote:admin:password": "pnpm --filter @ancient-epics/api remote:admin:password",
    "local:db:nuke": "pnpm --filter @ancient-epics/api local:db:nuke",
    "export:local": "pnpm --filter @ancient-epics/api export:local",
    "smoke": "pnpm --filter @ancient-epics/api smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
