{
  "name": "ancient-epics",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm --filter @ancient-epics/api dev\" \"pnpm --filter @ancient-epics/web dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @ancient-epics/api test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "seed:local": "pnpm --filter @ancient-epics/api seed:local",
    "seed:local:password": "pnpm --filter @ancient-epics/api seed:local:password",
    "seed:local:nuke": "pnpm --filter @ancient-epics/api seed:local:nuke",
    "export:local": "pnpm --filter @ancient-epics/api export:local",
    "smoke": "pnpm --filter @ancient-epics/api smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
